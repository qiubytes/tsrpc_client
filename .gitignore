# 依赖目录
node_modules/

# 编译输出目录（根据项目配置调整）
dist/
build/
out/
lib/

# TypeScript 编译后的文件（若未统一输出到目录，则单独忽略）
*.js
*.js.map
*.d.ts

# 环境变量文件
.env
.env.local
.env.*.local

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 测试覆盖率目录
coverage/
.nyc_output/

# 临时文件
tmp/
temp/

# 操作系统生成文件
.DS_Store
Thumbs.db

# IDE 配置（可根据需要保留）
.vscode/
.idea/
*.swp
*.swo
*~

# 打包文件
*.tgz
*.tar.gz

# 其他
.pnpm-store/
.eslintcache
.parcel-cache/